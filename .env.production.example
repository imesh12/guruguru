APP_DATA_DIR="./data"
ELECTRON_USER_DATA_DIR="./data/electron-user-data"
ELECTRON_CACHE_DIR="./data/electron-cache"
DATABASE_URL="file:./data/kurukuru.db"
KURUKURU_LOG_DIR="./data/logs"
API_HOST="127.0.0.1"
API_PORT="4000"
# Browser map / remote operator PC deployment:
# Set this to the LAN-reachable Ubuntu server IP or hostname, not 127.0.0.1.
# Example:
# VITE_API_BASE_URL="http://192.168.1.10:4000"
VITE_API_BASE_URL="http://<ubuntu-main-ip>:4000"
# Optional reference for server-side deployment planning.
API_BASE_URL="http://<ubuntu-main-ip>:4000"
VITE_MAPBOX_ACCESS_TOKEN=""
API_TOKEN="set-a-long-random-local-token"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="<scrypt-or-sha256-hash-placeholder>"
ADMIN_SESSION_SECRET="<change-me-random-secret>"
ADMIN_SESSION_TTL_SECONDS="28800"
CREDENTIAL_ENCRYPTION_KEY="set-a-32-byte-base64-key"
MEDIAMTX_AUTO_REGENERATE="true"
MEDIAMTX_RESTART_ON_CHANGE="true"
MEDIAMTX_SERVICE_NAME="KurukuruMediaMTX"
MEDIAMTX_CONFIG_PATH="C:\\KurukuruMonitor\\mediamtx\\mediamtx.yml"
# "webrtc" uses embedded wall playback through MediaMTX/WHEP.
# "mpv" keeps the wall on external mpv windows.
VITE_WALL_PLAYBACK_PROVIDER="webrtc"
# Controls whether embedded playback UI can be surfaced in the desktop app.
EMBEDDED_PLAYBACK_POC="false"
DEMO_MODE="false"
GPS_HISTORY_DAYS="30"
LOG_RETENTION_DAYS="14"
WATCHDOG_DELAYED_SEC="15"
WATCHDOG_OFFLINE_SEC="45"
SE220_RECEIVER_ENABLED="true"
SE220_RECEIVER_MODE="udp"
SE220_RECEIVER_PORT="5010"
SE220_VEHICLE_MAP='{"192.168.10.21":"vehicle-1","192.168.10.22":"vehicle-2"}'

# SE220 NMEA streaming PoC example:
# SE220_RECEIVER_ENABLED="true"
# SE220_RECEIVER_MODE="udp"
# SE220_RECEIVER_PORT="5018"
# SE220_DIRECT_POLLING_ENABLED="true"
# SE220_VEHICLE_MAP="{\"router-public-or-private-ip\":\"vehicle-id\"}"

# SE220 direct polling notes:
# - LAN recommendation: SE220_DIRECT_REQUEST_TIMEOUT_MS="800"
# - WAN recommendation: SE220_DIRECT_REQUEST_TIMEOUT_MS="1500"
# - GNSS sample freshness warning threshold can be tuned separately.
# SE220_DIRECT_POLLING_ENABLED="true"
# SE220_DIRECT_POLL_INTERVAL_MS="1000"
# SE220_DIRECT_REQUEST_TIMEOUT_MS="800"
# SE220_GNSS_STALE_THRESHOLD_MS="5000"
# SE220_DIRECT_ALLOW_SELF_SIGNED="true"
# SE220_DIRECT_POLLERS="vehicle-1|route-1|https://router-1.example.local|admin|<password>"

# Camera defaults are kept outside this production template on purpose.
# Store real RTSP passwords only in the Settings UI after deployment.
# Generate a valid CREDENTIAL_ENCRYPTION_KEY with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
