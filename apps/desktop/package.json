{
  "name": "@kurukuru-monitor/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "build": {
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:release": "electron-vite build",
    "start": "electron dist-electron/main/main.js",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.app.json --noEmit",
    "lint": "pnpm typecheck",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "mapbox-gl": "^3.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/google.maps": "^3.65.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^39.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.2",
    "wait-on": "^9.0.10"
  }
}